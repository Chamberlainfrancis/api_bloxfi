        },
        {
          "name": "Delete Wallet",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/wallets/external/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "wallets", "external", "{{walletId}}"]
            },
            "description": "204 or 200. Fails if wallet has pending transactions."
          }
        }
      ]
    },
