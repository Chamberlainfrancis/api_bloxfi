    {
      "name": "Onramps",
      "description": "Fiat → Crypto. Need userId, accountId, walletId. Create returns transferDetails.id (onrampId).",
      "item": [
        {
          "name": "Get Onramp Rates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onramps/rates?fromCurrency=USD&toCurrency=USDT",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "onramps", "rates"],
              "query": [
                { "key": "fromCurrency", "value": "USD" },
                { "key": "toCurrency", "value": "USDT" }
              ]
            },
            "description": "200: fromCurrency, toCurrency, conversionRate."
          }
        },
        {
          "name": "Create Onramp",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
