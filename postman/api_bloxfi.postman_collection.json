            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/wallets/external/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "wallets", "external", "{{walletId}}"]
            },
            "description": "200: updated wallet. Body: name?, active?."
