{
  "info": {
    "name": "BloxFi API",
    "description": "E2E testing for BloxFi API. Base URL: {{baseUrl}}/api/v1.\n\n**Auth:** Authorization: Bearer {{apiKey}} (32 alphanumeric chars).\n**Idempotent POSTs:** Each request that needs `requestId` has a Pre-request Script that auto-generates a new UUID and sets `requestId` before sending (no need to change it manually).\n\n**E2E flow:** Health → Create User → Get User → Update KYB → Upload File → Attach KYB Documents → Submit KYB → Get KYB Status → Create Account(s) → Add Wallet → Get Onramp Rates → Create Onramp → Get Onramp → Get Offramp Rates → Create Offramp → Get Offramp → Cancel Offramp (optional) → Get Limits → Get User Limits → Create High-Value Request → Get High-Value Request.\n\nRequests with test scripts auto-save response IDs to collection variables (userId, fileId, accountId, walletId, onrampId, offrampId, highValueRequestId). Run in order or set variables manually.\n\nSee docs/E2E_FLOW_GUIDE_POSTMAN.md for full step-by-step guide.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "apiKey", "value": "your-api-key-min-32-characters-long" },
    { "key": "userId", "value": "" },
    { "key": "fileId", "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "walletId", "value": "" },
    { "key": "onrampId", "value": "" },
    { "key": "offrampId", "value": "" },
    { "key": "highValueRequestId", "value": "" },
    { "key": "requestId", "value": "705f1f8b-a080-467c-b683-174eca409928" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{apiKey}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "No auth. 200: { success: true, data: { status: 'ok', timestamp } }."
          }
        }
      ]
    },
    {
      "name": "Files",
      "description": "Upload file (max 10MB; PDF, JPEG, PNG). Save data.fileId for Attach KYB Documents.",
      "item": [
        {
          "name": "Upload File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 && pm.response.json().success && pm.response.json().data && pm.response.json().data.fileId) {",
                  "    pm.collectionVariables.set('fileId', pm.response.json().data.fileId);",
                  "    console.log('Saved fileId: ' + pm.response.json().data.fileId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select a PDF, JPEG, or PNG file (max 10MB)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "files"]
            },
            "description": "Multipart form-data, field 'file'. 201: fileId, filename, size, mimeType, uploadedAt. fileId is auto-saved."
          }
        }
      ]
    },
    {
      "name": "User",
      "description": "User and KYB. Create User first; save userId for all other user-scoped requests.",
      "item": [
        {
          "name": "Create Business User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "pm.collectionVariables.set('requestId', uuidv4());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 && pm.response.json().success && pm.response.json().data && pm.response.json().data.id) {",
                  "    pm.collectionVariables.set('userId', pm.response.json().data.id);",
                  "    console.log('Saved userId: ' + pm.response.json().data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "requestId", "value": "{{requestId}}", "description": "Auto-set by Pre-request Script (new UUID each send)" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"business\",\n  \"businessInfo\": {\n    \"legalName\": \"Acme Corporation Ltd\",\n    \"tradingName\": \"Acme Corp\",\n    \"registrationNumber\": \"12345678\",\n    \"entityType\": \"LIMITED_COMPANY\",\n    \"dateOfIncorporation\": \"2020-01-15\",\n    \"taxIdentificationNumber\": \"GB123456789\",\n    \"website\": \"https://www.acmecorp.com\",\n    \"industry\": \"TECHNOLOGY\",\n    \"email\": \"admin@acmecorp.com\",\n    \"phone\": \"+442071234567\"\n  },\n  \"registeredAddress\": {\n    \"addressLine1\": \"123 Business Street\",\n    \"addressLine2\": \"Suite 400\",\n    \"city\": \"London\",\n    \"stateProvinceRegion\": \"England\",\n    \"postalCode\": \"EC1A 1BB\",\n    \"country\": \"GBR\"\n  },\n  \"legalRepresentative\": {\n    \"firstName\": \"John\",\n    \"lastName\": \"Smith\",\n    \"email\": \"john.smith@acmecorp.com\",\n    \"phone\": \"+442071234567\",\n    \"dateOfBirth\": \"1980-05-15\",\n    \"position\": \"Director\",\n    \"address\": {\n      \"addressLine1\": \"456 Residential Road\",\n      \"city\": \"London\",\n      \"stateProvinceRegion\": \"England\",\n      \"postalCode\": \"SW1A 1AA\",\n      \"country\": \"GBR\"\n    }\n  },\n  \"metadata\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "201: id, type, status, businessInfo, kybStatus, createdAt. userId is auto-saved."
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}"]
            },
            "description": "200: full user; 404 if not found."
          }
        },
        {
          "name": "Update KYB Information",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "pm.collectionVariables.set('requestId', uuidv4());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "requestId", "value": "{{requestId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessDetails\": {\n    \"numberOfEmployees\": \"51-200\",\n    \"annualRevenue\": \"1000000-5000000\",\n    \"sourceOfFunds\": \"BUSINESS_REVENUE\",\n    \"purposeOfAccount\": \"CROSS_BORDER_PAYMENTS\",\n    \"expectedMonthlyVolume\": \"100000-500000\",\n    \"businessDescription\": \"Technology consulting and software development\"\n  },\n  \"beneficialOwners\": [\n    {\n      \"firstName\": \"Jane\",\n      \"lastName\": \"Doe\",\n      \"dateOfBirth\": \"1975-08-22\",\n      \"nationality\": \"GBR\",\n      \"ownershipPercentage\": 60,\n      \"isPoliticallyExposed\": false,\n      \"address\": {\n        \"addressLine1\": \"789 Owner Avenue\",\n        \"city\": \"London\",\n        \"postalCode\": \"W1A 1AA\",\n        \"country\": \"GBR\"\n      }\n    }\n  ],\n  \"directors\": [\n    {\n      \"firstName\": \"John\",\n      \"lastName\": \"Smith\",\n      \"dateOfBirth\": \"1980-05-15\",\n      \"nationality\": \"GBR\",\n      \"position\": \"CEO\",\n      \"isPoliticallyExposed\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/kyb",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "kyb"]
            },
            "description": "200: status, missingFields, nextSteps."
          }
        },
        {
          "name": "Attach KYB Documents",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"type\": \"CERTIFICATE_OF_INCORPORATION\",\n    \"fileId\": \"{{fileId}}\",\n    \"issuedCountry\": \"GBR\",\n    \"issueDate\": \"2020-01-15\",\n    \"expiryDate\": null\n  },\n  {\n    \"type\": \"DIRECTOR_ID\",\n    \"subType\": \"PASSPORT\",\n    \"fileId\": \"{{fileId}}\",\n    \"issuedCountry\": \"GBR\",\n    \"documentNumber\": \"123456789\",\n    \"issueDate\": \"2020-06-01\",\n    \"expiryDate\": \"2030-06-01\",\n    \"ownerName\": \"John Smith\"\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/kyb/documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "kyb", "documents"]
            },
            "description": "Array of { type, fileId, ... }. 201: documentsAdded, documents[]."
          }
        },
        {
          "name": "Submit KYB Application",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function uuidv4() {",
                  "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
                  "    var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);",
                  "    return v.toString(16);",
                  "  });",
                  "}",
                  "pm.collectionVariables.set('requestId', uuidv4());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "requestId", "value": "{{requestId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rails\": [\"USD\", \"EUR\", \"GBP\"],\n  \"priority\": \"standard\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/kyb/submissions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "kyb", "submissions"]
            },
            "description": "201: submissionId, status, rails, submittedAt, estimatedCompletionDate."
          }
        },
        {
          "name": "Get KYB Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/kyb/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "kyb", "status"]
            },
            "description": "200: userId, overallStatus, railStatuses[], lastUpdated. Add ?rails=USD,EUR to filter."
          }
        },
        {
          "name": "Get User Limits",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/limits",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "limits"]
            },
            "description": "200: userId, effectiveLimits[], limitIncreaseEligibility, lastUpdated."
          }
        }
      ]
    },
