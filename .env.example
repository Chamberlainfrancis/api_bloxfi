# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/bloxfi?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-at-least-32-chars
API_KEY_HEADER=Authorization

# Optional: CORS allowed origins (comma-separated; empty = use default)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Rate limit: requests per window per key
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Idempotency: TTL for requestId in Redis (seconds)
IDEMPOTENCY_TTL_SECONDS=86400

# Optional: S3-compatible storage (e.g. for file uploads)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=auto
# S3_BUCKET=your-bucket
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Currency API: rates for onramp/offramp (docs/exchange-rates-api.md). Used as sole rate source when set.
# If unset, PALREMIT_CURRENCY_URL is used (backward compatible).
# CURRENCY_API_URL=https://currency-api.example.com

# Palremit: onramp/offramp liquidity and optional rate fallback (see docs/API_INTEGRATION_GUIDE.md)
# Currency API = rates. Liquidity API = ramp orders, deposits, withdrawals (access_key).
PALREMIT_CURRENCY_URL=https://currency-api.palremit.com
PALREMIT_LIQUIDITY_URL=https://liquidity-api.palremit.com
PALREMIT_ACCESS_KEY=your_palremit_access_key

# Optional: generic LP (BloxFi-spec style). Used as fallback when Palremit is not configured or returns no result.
# LP_BASE_URL=https://lp.example.com
# LP_API_KEY=your_lp_api_key

# Inbound webhooks from LPs (POST /api/v1/webhooks). HMAC SHA256(webhook_id.timestamp.body).
# If unset, signature verification is skipped (not recommended for production).
# WEBHOOK_SECRET=your_webhook_secret
