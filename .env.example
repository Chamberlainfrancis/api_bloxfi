# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/bloxfi?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-at-least-32-chars
API_KEY_HEADER=Authorization

# Optional: CORS allowed origins (comma-separated; empty = use default)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Rate limit: requests per window per key
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Idempotency: TTL for requestId in Redis (seconds)
IDEMPOTENCY_TTL_SECONDS=86400
