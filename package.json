{
  "name": "api-bloxfi",
  "version": "0.1.0",
  "description": "BloxFi aggregation API",
  "author": {
    "name": "Chamberlain",
    "email": "chamberlainfrancis@gmail.com",
    "url": "https://github.com/Chamberlainfrancis"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "create-api-key": "ts-node scripts/create-api-key.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "pg": "^8.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "prisma": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
